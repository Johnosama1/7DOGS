{
  "version": 2,
  "builds": [
    {
      "src": "bot/src/bot.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "bot/src/bot.js"
    },
    {
      "src": "/health",
      "dest": "bot/src/bot.js"
    },
    {
      "src": "/(.*)",
      "dest": "bot/src/bot.js"
    }
  ]
}
