modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["inshellisense"]

[userenv]

[userenv.shared]
PORT = "5000"
API_PORT = "3001"
MINI_APP_URL = "https://86798c03-7440-4d00-8532-0160c1cd6f6c-00-xa447zz0hain.spock.replit.dev"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "7DOGS Bot"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "7DOGS Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bot && node start-polling.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23860
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 node --enable-source-maps /home/runner/workspace/artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build && PORT=5000 pnpm --filter @workspace/7dogs run build"]
